+                "incompatible save: missing campaign_parties.{field}"
+            ));
+        }
+    }
+
+    let parties = campaign_parties
+        .get("parties")
+        .and_then(|v| v.as_array())
+        .ok_or_else(|| "incompatible save: campaign_parties.parties must be an array".to_string())?;
+
+    for (idx, party) in parties.iter().enumerate() {
+        let party_obj = party
+            .as_object()
+            .ok_or_else(|| format!("incompatible save: campaign_parties.parties[{idx}] must be an object"))?;
