+    #[serde(default)]
+    intro_completed: bool,
+    #[serde(default)]
+    region_payload: Option<RegionTransitionPayload>,
+    #[serde(default)]
+    local_source_region_id: Option<usize>,
+}
+
+impl Default for CampaignProgressState {
+    fn default() -> Self {
+        Self {
+            current_layer: CampaignLayerMarker::Overworld,
+            current_region_id: None,
+            local_scene_id: None,
+            intro_completed: false,
+            region_payload: None,
+            local_source_region_id: None,
+        }
+    }
+}
