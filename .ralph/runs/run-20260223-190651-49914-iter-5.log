pub fn overworld_cooldown_system(run_state: Res<RunState>, mut overworld: ResMut<OverworldMap>) {
    if run_state.global_turn == 0 {
        return;
    }
    if overworld.travel_cooldown_turns > 0 {
        overworld.travel_cooldown_turns -= 1;
    }
}

