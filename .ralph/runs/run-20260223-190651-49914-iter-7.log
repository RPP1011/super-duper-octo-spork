fn format_slot_meta(meta: Option<&SaveSlotMetadata>) -> String {
    match meta {
        Some(m) => format!(
            "{} t{} v{} seed={} ts={} {}",
            m.slot,
            m.global_turn,
            m.save_version,
            m.map_seed,
            m.saved_unix_seconds,
            if m.compatible { "ok" } else { "incompatible" }
        ),
        None => "empty".to_string(),
    }
}

