+fn hub_runtime_input_enabled(
+    hub_ui: &HubUiState,
+    transition_state: Option<&RegionLayerTransitionState>,
+) -> bool {
+    if transition_state.is_some_and(|state| state.interaction_locked) {
+        return false;
+    }
+    matches!(
+        hub_ui.screen,
+        HubScreen::GuildManagement | HubScreen::Overworld | HubScreen::OverworldMap
+    )
+}
+
+fn run_if_hub_runtime_active(
+    hub_ui: Option<Res<HubUiState>>,
+    transition_state: Option<Res<RegionLayerTransitionState>>,
+) -> bool {
+    match hub_ui.as_ref() {
+        Some(ui) => hub_runtime_input_enabled(ui, transition_state.as_deref()),
+        None => false,
+    }
