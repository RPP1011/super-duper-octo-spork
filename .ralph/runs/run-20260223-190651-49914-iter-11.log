+        let baseline = fixture
+            .iter()
+            .map(|capture| (capture.stage, capture.signature))
+            .collect::<BTreeMap<RegressionStage, u64>>();
+        assert!(verify_regression_baseline(&deduped, &baseline).is_ok());
