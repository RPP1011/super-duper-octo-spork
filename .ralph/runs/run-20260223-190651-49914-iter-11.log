+                    "screen": "OverworldMap",
+                    "map_seed": overworld.map_seed,
+                    "selected_region_id": overworld.selected_region,
+                    "player_party_id": player_party.id,
+                    "player_party_region_id": player_party.region_id
+                }),
+            ),
+            capture_for_stage(
