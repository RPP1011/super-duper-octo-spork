+        );
+        assert_eq!(
+            transition.active.as_ref().map(|t| t.target_region_id),
+            Some(7)
+        );
+
+        let mut last_focus = mid_step.focus;
+        let mut completed = false;
+        for _ in 0..24 {
+            if let Some(step) = transition.step(0.05) {
+                last_focus = step.focus;
+                if step.completed {
+                    completed = true;
+                    break;
+                }
+            }
+        }
+
+        assert!(completed);
