        Ok(()) => {
            println!("Scenario template written to: {}", path);
            println!("Edit the json and run --scenario-viz <path> to visualize it.");
        }
        Err(err) => {
            eprintln!("Failed to write scenario template: {}", err);
        }
    }
}

