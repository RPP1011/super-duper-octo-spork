+            stat_modifiers: vec!["Scouting: +2".to_string()],
+            recruit_bias_modifiers: vec!["Recruit Bias: Tactician and Vanguard +15%".to_string()],
+            is_confirmed: true,
+        };
+        let mut diplomacy = game_core::DiplomacyState::default();
+        let mut hub_ui = HubUiState {
