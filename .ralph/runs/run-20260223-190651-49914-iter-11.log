impl HubAction {
    fn from_selected(selected: usize) -> Self {
        match selected {
            0 => Self::AssembleExpedition,
            1 => Self::ReviewRecruits,
            2 => Self::IntelSweep,
            3 => Self::DispatchRelief,
            _ => Self::LeaveGuild,
