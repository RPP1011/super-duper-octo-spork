+
+impl RegionTargetPickerState {
+    fn active_party_id(&self) -> Option<u32> {
+        match self.mode {
+            RegionTargetPickerMode::Picking { party_id, .. } => Some(party_id),
+            RegionTargetPickerMode::Inactive => None,
+        }
