+            player_stress_delta: -2.0,
+            player_fatigue_delta: -1.0,
+            party_speed_delta: 0.05,
+            party_supply_delta: 12.0,
+        },
+        BackstorySelectionChoice {
+            id: "raider-veteran",
+            name: "Raider",
+            summary: "You learned to hit quickly, live lean, and leave before reprisals landed.",
+            stat_modifiers: vec![
