+                serde_json::json!({
+                    "seed_label": seed_label,
+                    "screen": "StartMenu",
+                    "subtitle": StartMenuState::default_subtitle(),
+                    "status": StartMenuState::default_status()
+                }),
+            ),
+            capture_for_stage(
+                RegressionStage::CharacterCreation,
+                serde_json::json!({
