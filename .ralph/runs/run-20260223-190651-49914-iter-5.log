+        .unwrap_or_else(|| "none".to_string())
+}
+
+fn party_panel_label(
+    party: &game_core::CampaignParty,
+    is_selected: bool,
+    leader: &str,
+    region: &str,
+    target_region: &str,
+) -> String {
+    let selected_marker = if is_selected { "[SELECTED] " } else { "" };
+    let control_marker = if party.is_player_controlled {
