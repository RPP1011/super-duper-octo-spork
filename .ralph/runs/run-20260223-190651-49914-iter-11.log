+
+        assert_eq!(first, second);
+        let stages = first.iter().map(|capture| capture.stage).collect::<Vec<_>>();
+        assert_eq!(stages, REGRESSION_STAGES);
+    }
+
+    #[test]
+    fn campaign_regression_stage_capture_supports_dedupe_and_baseline_checks() {
